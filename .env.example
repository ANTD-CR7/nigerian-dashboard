# Copy this file to .env locally (or set these in the Render dashboard for
# production) and fill in real values. Never commit the real .env file.
# If unset, main.py falls back to the existing public anon key so local/dev
# runs and the current Render deploy keep working unchanged.

SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Set to "true" to allow POST /api/v1/observations and /api/v1/ingest/csv to
# actually write to the database. Defaults to "false" (demo-safe: validates
# and normalizes rows but never commits them).
ALLOW_DATA_WRITES=false
