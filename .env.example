# Copy this file to .env locally (or set these in the Render dashboard for
# production) and fill in real values. Never commit the real .env file.
# If unset, main.py falls back to the existing public anon key so local/dev
# runs and the current Render deploy keep working unchanged.

SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Set to "true" to allow POST /api/v1/observations and /api/v1/ingest/csv to
# actually write to the database. Defaults to "false" (demo-safe: validates
# and normalizes rows but never commits them).
ALLOW_DATA_WRITES=false

# Optional: enable the AI "ask the data" assistant (POST /api/v1/ask).
# Without ANTHROPIC_API_KEY the endpoint returns 503 and the rest of the API
# is unaffected. NPE_AI_MODEL is optional (defaults to claude-sonnet-5).
ANTHROPIC_API_KEY=
NPE_AI_MODEL=claude-sonnet-5

# Optional: API-key auth + simple rate limiting. Leave NPE_API_KEYS blank to
# keep the API fully open (current behaviour). Set a comma-separated list of
# accepted keys to require an X-API-Key header on data endpoints.
NPE_API_KEYS=
NPE_RATE_LIMIT_PER_MIN=120
